## Frontend (Vite) environment variables
## Copy this file to `.env` and adjust as needed.

# Backend API base URL
VITE_API_URL=http://localhost:8082

# Keycloak base URL (Auth server)
VITE_KEYCLOAK_URL=http://localhost:8080

# Keycloak realm name
VITE_KEYCLOAK_REALM=TicketRush

# Keycloak client id (Public client for SPA)
VITE_KEYCLOAK_CLIENT_ID=TicketRush_Client

# Disable login-status iframe check to avoid 3rd-party cookie/iframe timeouts (recommended for local dev)
VITE_KEYCLOAK_CHECK_LOGIN_IFRAME=false

